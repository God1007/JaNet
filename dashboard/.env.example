# Dashboard AI 配置示例：复制为 .env 后填写服务端读取的 DeepSeek Key。
# 鉴权密钥仅由 Node BFF 读取，不应暴露给 Vite 客户端变量。
DEEPSEEK_API_KEY=sk-your-deepseek-key
# OpenAI-compatible 服务地址和模型可按部署环境覆盖。
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# 默认关闭思考模式，降低本地看板诊断延迟。
DEEPSEEK_THINKING=disabled

# Chrome 真实请求失败按 host + failureCode 聚合；默认 5 分钟内 5 次触发告警。
DASHBOARD_REQUEST_FAILURE_WINDOW_SEC=300
DASHBOARD_REQUEST_FAILURE_THRESHOLD=5
# BFF 只保留最近 500 条失败终态，避免长时间运行时无界增长。
DASHBOARD_REQUEST_FAILURE_MAX_RECENT=500

# 同时到达的多标签页快照复用一轮采集；成功结果只短暂缓存 2 秒。
DASHBOARD_SNAPSHOT_CACHE_TTL_MS=2000

# 可选配对加固：默认依靠 loopback + 合法 chrome-extension:// Origin 即可使用。
# ID 可在 chrome://extensions 或扩展 Options 页面查看；token 需在两侧填写相同值。
# DASHBOARD_BROWSER_EXTENSION_ID=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
# DASHBOARD_BROWSER_EXTENSION_TOKEN=replace-with-a-random-local-token
