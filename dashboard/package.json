{
  "name": "weaknet-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c green,cyan \"npm:server\" \"npm:client\"",
    "server": "node server/index.mjs",
    "client": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "tsc --noEmit && vite build",
    "test:unit": "node --test server/metric_compat.test.mjs server/resource_guards.test.mjs src/lib/rtt_format.test.mjs src/lib/traffic_metrics.test.mjs src/lib/latency_series.test.mjs src/lib/series_selection.test.mjs"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.13.4",
    "@grpc/proto-loader": "^0.8.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.0",
    "typescript": "^5.8.3",
    "vite": "^8.1.3"
  }
}
