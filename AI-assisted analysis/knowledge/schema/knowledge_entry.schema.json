{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weaknet.local/schemas/knowledge-entry-2.0.0.json",
  "title": "WeakNet structured knowledge document",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kb_version", "entries"],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "kb_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "description": {"type": "string"},
    "merge_metadata": {"type": "object"},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/entry"}
    }
  },
  "$defs": {
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operator", "value"],
      "properties": {
        "operator": {"enum": ["gt", "ge", "lt", "le", "eq", "between", "none"]},
        "value": {"type": ["number", "string", "null"]},
        "max_value": {"type": ["number", "string"]}
      },
      "allOf": [
        {
          "if": {"properties": {"operator": {"const": "between"}}},
          "then": {"required": ["max_value"]}
        }
      ]
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id", "metric", "condition", "threshold", "unit",
        "symptoms", "root_causes", "actions", "severity", "tags",
        "source", "source_revision", "source_anchor", "updated_at", "review_status",
        "reviewed_by", "reviewed_at", "reviewed_by_human"
      ],
      "properties": {
        "entry_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"},
        "metric": {"type": "string", "minLength": 1},
        "condition": {"type": "string", "minLength": 1},
        "threshold": {"$ref": "#/$defs/threshold"},
        "unit": {"type": "string", "minLength": 1},
        "symptoms": {"$ref": "#/$defs/nonEmptyStringArray"},
        "root_causes": {"$ref": "#/$defs/nonEmptyStringArray"},
        "actions": {"$ref": "#/$defs/nonEmptyStringArray"},
        "severity": {"enum": ["info", "low", "medium", "high", "critical"]},
        "tags": {"$ref": "#/$defs/nonEmptyStringArray"},
        "source": {"type": "string", "minLength": 1},
        "source_revision": {"type": "string", "minLength": 1},
        "source_anchor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["symbol", "line_start", "line_end", "claim", "excerpt_sha256", "semantic_sha256"],
          "properties": {
            "symbol": {"type": "string", "minLength": 1},
            "line_start": {"type": "integer", "minimum": 1},
            "line_end": {"type": "integer", "minimum": 1},
            "claim": {"type": "string", "minLength": 1},
            "excerpt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "semantic_sha256": {
              "type": "object",
              "additionalProperties": false,
              "required": ["condition", "symptoms", "root_causes", "actions"],
              "properties": {
                "condition": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
                "symptoms": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
                "root_causes": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
                "actions": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
              }
            }
          }
        },
        "updated_at": {"type": "string", "format": "date-time"},
        "review_status": {"enum": ["draft", "approved", "rejected"]},
        "reviewed_by": {"type": ["string", "null"]},
        "reviewed_at": {"type": ["string", "null"], "format": "date-time"},
        "reviewed_by_human": {"type": "boolean"}
      }
    }
  }
}
